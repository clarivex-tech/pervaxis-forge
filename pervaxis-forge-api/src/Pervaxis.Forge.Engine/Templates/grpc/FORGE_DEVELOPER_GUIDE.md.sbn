using Microsoft.Extensions.Logging;
using Pervaxis.Genesis.Caching;
using {{ model.names.namespace }}.Data;

namespace {{ model.names.namespace }}.Services;

public sealed class {{ model.names.dot_net_class_name }} : I{{ model.names.dot_net_class_name }}
{
    private readonly IYourDomainRepository _repository;
    private readonly ICache _cache;
    private readonly ILogger<{{ model.names.dot_net_class_name }}> _logger;

    public {{ model.names.dot_net_class_name }}(
        IYourDomainRepository repository,
        ICache cache,
        ILogger<{{ model.names.dot_net_class_name }}> logger)
    {
        _repository = repository;
        _cache = cache;
        _logger = logger;
    }

    public async Task<YourDomainRecord> GetAsync(string id, CancellationToken ct = default)
    {
        var cacheKey = "{{ model.names.cache_prefix }}{id}";
        var cached = await _cache.GetAsync<YourDomainRecord>(cacheKey, ct);
        if (cached is not null)
            return cached;

        var entity = await _repository.GetByIdAsync(id, ct)
            ?? throw new YourDomainNotFoundException(id);

        var record = entity.ToDomain();
        await _cache.SetAsync(cacheKey, record, TimeSpan.FromMinutes(5), ct);
        return record;
    }
}
```

### Step 2 — Implement the gRPC service override in `ServiceImpl.cs`

```csharp
// ServiceImpl.cs — extend the generated scaffold
public sealed class {{ model.names.dot_net_class_name }}ServiceImpl : {{ model.names.dot_net_class_name }}Service.{{ model.names.dot_net_class_name }}ServiceBase
{
    private readonly I{{ model.names.dot_net_class_name }} _service;
    private readonly ILogger<{{ model.names.dot_net_class_name }}ServiceImpl> _logger;

    public {{ model.names.dot_net_class_name }}ServiceImpl(
        I{{ model.names.dot_net_class_name }} service,
        ILogger<{{ model.names.dot_net_class_name }}ServiceImpl> logger)
    {
        _service = service;
        _logger = logger;
    }

    public override async Task<RecordResponse> Get(GetRequest request, ServerCallContext context)
    {
        try
        {
            var record = await _service.GetAsync(request.Id, context.CancellationToken);
            return record.ToResponse();
        }
        catch (YourDomainNotFoundException ex)
        {
            _logger.LogWarning("Record {RecordId} not found", ex.RecordId);
            throw new RpcException(new Status(StatusCode.NotFound, ex.Message));
        }
    }

    public override async Task<RecordResponse> Create(CreateRequest request, ServerCallContext context)
    {
        try
        {
            var record = await _service.CreateAsync(request.ToDomain(), context.CancellationToken);
            return record.ToResponse();
        }
        catch (YourDomainDuplicateException ex)
        {
            _logger.LogWarning("Duplicate reference {Reference}", ex.Reference);
            throw new RpcException(new Status(StatusCode.AlreadyExists, ex.Message));
        }
    }

    public override async Task<DeleteResponse> Delete(DeleteRequest request, ServerCallContext context)
    {
        try
        {
            await _service.DeleteAsync(request.Id, context.CancellationToken);
            return new DeleteResponse { Success = true };
        }
        catch (YourDomainNotFoundException ex)
        {
            _logger.LogWarning("Record {RecordId} not found for delete", ex.RecordId);
            throw new RpcException(new Status(StatusCode.NotFound, ex.Message));
        }
    }

    public override async Task List(ListRequest request, IServerStreamWriter<RecordResponse> stream, ServerCallContext context)
    {
        var records = await _service.ListAsync(request.Page, request.PageSize, context.CancellationToken);
        foreach (var record in records)
            await stream.WriteAsync(record.ToResponse(), context.CancellationToken);
    }
}
```

### gRPC status code mapping

| Domain exception | gRPC StatusCode |
|---|---|
| `YourDomainNotFoundException` | `StatusCode.NotFound` |
| `YourDomainDuplicateException` | `StatusCode.AlreadyExists` |
| Validation failure | `StatusCode.InvalidArgument` |
| Unauthorized | `StatusCode.PermissionDenied` |
| Unexpected | `StatusCode.Internal` |

