## 9. Testing

### Unit test — service logic

```csharp
public sealed class {{ model.names.dot_net_class_name }}Tests
{
    private readonly Mock<IYourDomainRepository> _repository = new();
    private readonly Mock<ICache> _cache = new();
    private readonly Mock<ILogger<{{ model.names.dot_net_class_name }}>> _logger = new();
    private readonly {{ model.names.dot_net_class_name }} _sut;

    public {{ model.names.dot_net_class_name }}Tests() =>
        _sut = new {{ model.names.dot_net_class_name }}(_repository.Object, _cache.Object, _logger.Object);

    [Fact]
    public async Task GetAsync_WhenNotFound_ThrowsNotFoundException()
    {
        _cache.Setup(c => c.GetAsync<YourDomainRecord>(It.IsAny<string>(), default))
              .ReturnsAsync((YourDomainRecord?)null);
        _repository.Setup(r => r.GetByIdAsync("missing", default))
                   .ReturnsAsync((YourDomainEntity?)null);

        var act = () => _sut.GetAsync("missing");

        await act.Should().ThrowAsync<YourDomainNotFoundException>();
    }
}
```

### Integration test — gRPC endpoint

```csharp
public sealed class {{ model.names.dot_net_class_name }}ServiceImplTests : TestBase
{
    private readonly Mock<I{{ model.names.dot_net_class_name }}> _service = new();

    protected override void ConfigureTestServices(IServiceCollection services)
    {
        services.AddScoped<I{{ model.names.dot_net_class_name }}>(_ => _service.Object);
    }

    [Fact]
    public async Task Get_WithValidId_ReturnsRecord()
    {
        _service.Setup(s => s.GetAsync("1", default))
                .ReturnsAsync(new YourDomainRecord { Id = "1", Reference = "REF-001", Status = "Open", CreatedAt = DateTimeOffset.UtcNow });

        var channel = GrpcChannel.ForAddress(Client.BaseAddress!, new GrpcChannelOptions { HttpClient = Client });
        var grpcClient = new {{ model.names.dot_net_class_name }}Service.{{ model.names.dot_net_class_name }}ServiceClient(channel);

        var response = await grpcClient.GetAsync(new GetRequest { Id = "1" });

        response.Id.Should().Be("1");
        response.Reference.Should().Be("REF-001");
    }

    [Fact]
    public async Task Get_WhenNotFound_ThrowsRpcNotFound()
    {
        _service.Setup(s => s.GetAsync("missing", default))
                .ThrowsAsync(new YourDomainNotFoundException("missing"));

        var channel = GrpcChannel.ForAddress(Client.BaseAddress!, new GrpcChannelOptions { HttpClient = Client });
        var grpcClient = new {{ model.names.dot_net_class_name }}Service.{{ model.names.dot_net_class_name }}ServiceClient(channel);

        var act = () => grpcClient.GetAsync(new GetRequest { Id = "missing" }).ResponseAsync;

        var ex = await act.Should().ThrowAsync<RpcException>();
        ex.Which.StatusCode.Should().Be(StatusCode.NotFound);
    }
}
```

