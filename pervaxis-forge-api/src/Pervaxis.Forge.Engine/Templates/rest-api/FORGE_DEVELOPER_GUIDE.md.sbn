## 5a. BFF Pattern (Backend for Frontend)

If this service aggregates multiple downstream APIs for a frontend, apply the BFF pattern in the service layer:

```csharp
public sealed class {{ model.names.dot_net_class_name }} : I{{ model.names.dot_net_class_name }}
{
    private readonly IDownstreamOrdersClient _orders;
    private readonly IDownstreamProductsClient _products;
    private readonly ICache _cache;

    // Aggregate downstream responses — shape data for UI, hide internal complexity
    public async Task<DashboardSummaryResponse> GetDashboardAsync(string tenantId, CancellationToken ct)
    {
        var cacheKey = "{{ model.names.cache_prefix }}dashboard:{tenantId}";
        var cached = await _cache.GetAsync<DashboardSummaryResponse>(cacheKey, ct);
        if (cached is not null)
            return cached;

        // Fan-out calls — run in parallel
        var (orders, products) = await (
            _orders.GetSummaryAsync(tenantId, ct),
            _products.GetActiveCountAsync(tenantId, ct)
        ).WhenAll();

        var response = new DashboardSummaryResponse
        {
            TotalOrders = orders.Count,
            ActiveProducts = products.Count,
            GeneratedAt = DateTimeOffset.UtcNow
        };

        await _cache.SetAsync(cacheKey, response, TimeSpan.FromMinutes(2), ct);
        return response;
    }
}
```

Register downstream HTTP clients in `Extensions/ServiceCollectionExtensions.cs`:

```csharp
services.AddHttpClient<IDownstreamOrdersClient, DownstreamOrdersClient>(client =>
    client.BaseAddress = new Uri(configuration["Downstream:Orders:BaseUrl"]!));
```

