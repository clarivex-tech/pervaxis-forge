## 5. Controller Patterns

Extend the scaffold controller at `Controllers/Controller.cs` with the full CRUD surface.

```csharp
[ApiController]
[Route("{{ model.names.api_base_route }}")]
[Produces("application/json")]
public sealed class {{ model.names.dot_net_class_name }}Controller : ControllerBase
{
    private readonly I{{ model.names.dot_net_class_name }} _service;
    private readonly ILogger<{{ model.names.dot_net_class_name }}Controller> _logger;

    public {{ model.names.dot_net_class_name }}Controller(
        I{{ model.names.dot_net_class_name }} service,
        ILogger<{{ model.names.dot_net_class_name }}Controller> logger)
    {
        _service = service;
        _logger = logger;
    }

    [HttpGet("{id}")]
    [ProducesResponseType(typeof({{ model.names.dot_net_class_name }}Response), StatusCodes.Status200OK)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    public async Task<IActionResult> GetAsync(string id, CancellationToken cancellationToken)
    {
        try
        {
            var result = await _service.GetAsync(id, cancellationToken);
            return Ok(result);
        }
        catch (YourDomainNotFoundException ex)
        {
            _logger.LogWarning("Record {RecordId} not found", ex.RecordId);
            return NotFound(new ProblemDetails { Detail = ex.Message });
        }
    }

    [HttpPost]
    [ProducesResponseType(typeof({{ model.names.dot_net_class_name }}Response), StatusCodes.Status201Created)]
    [ProducesResponseType(StatusCodes.Status400BadRequest)]
    [ProducesResponseType(StatusCodes.Status409Conflict)]
    public async Task<IActionResult> CreateAsync(
        [FromBody] Create{{ model.names.dot_net_class_name }}Request request,
        CancellationToken cancellationToken)
    {
        try
        {
            var result = await _service.CreateAsync(request, cancellationToken);
            return CreatedAtAction(nameof(GetAsync), new { id = result.Id }, result);
        }
        catch (YourDomainDuplicateException ex)
        {
            _logger.LogWarning("Duplicate reference {Reference}", ex.Reference);
            return Conflict(new ProblemDetails { Detail = ex.Message });
        }
    }

    [HttpPut("{id}")]
    [ProducesResponseType(typeof({{ model.names.dot_net_class_name }}Response), StatusCodes.Status200OK)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    public async Task<IActionResult> UpdateAsync(
        string id,
        [FromBody] Update{{ model.names.dot_net_class_name }}Request request,
        CancellationToken cancellationToken)
    {
        try
        {
            var result = await _service.UpdateAsync(id, request, cancellationToken);
            return Ok(result);
        }
        catch (YourDomainNotFoundException ex)
        {
            _logger.LogWarning("Record {RecordId} not found for update", ex.RecordId);
            return NotFound(new ProblemDetails { Detail = ex.Message });
        }
    }

    [HttpDelete("{id}")]
    [ProducesResponseType(StatusCodes.Status204NoContent)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    public async Task<IActionResult> DeleteAsync(string id, CancellationToken cancellationToken)
    {
        try
        {
            await _service.DeleteAsync(id, cancellationToken);
            return NoContent();
        }
        catch (YourDomainNotFoundException ex)
        {
            _logger.LogWarning("Record {RecordId} not found for delete", ex.RecordId);
            return NotFound(new ProblemDetails { Detail = ex.Message });
        }
    }

    [HttpGet]
    [ProducesResponseType(typeof(IReadOnlyList<{{ model.names.dot_net_class_name }}Response>), StatusCodes.Status200OK)]
    public async Task<IActionResult> ListAsync(
        [FromQuery] int page = 1,
        [FromQuery] int pageSize = 20,
        CancellationToken cancellationToken = default)
    {
        var results = await _service.ListAsync(page, pageSize, cancellationToken);
        return Ok(results);
    }
}
```

**Rules:**
- `[ApiController]` automatically returns `ValidationProblem` (HTTP 400) on model validation failure — no need to check `ModelState` manually for bound models
- Always use `ProblemDetails` for error responses — never return plain strings
- Decorate every action with `[ProducesResponseType]` — required for accurate Swagger docs
- Log at the service layer, not the controller

