## 6. Data Access

### Add EF Core to the project

Add to `{{ model.names.namespace }}.csproj`:

```xml
<PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.*" />
<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.*" />
<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.*">
  <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
  <PrivateAssets>all</PrivateAssets>
</PackageReference>
```

Register in `Extensions/ServiceCollectionExtensions.cs`:

```csharp
var connectionString = configuration.GetConnectionString("{{ model.names.dot_net_class_name }}")
    ?? throw new InvalidOperationException("Connection string '{{ model.names.dot_net_class_name }}' is not configured.");

services.AddDbContext<YourDomainDbContext>(opts =>
    opts.UseNpgsql(connectionString, npgsql =>
        npgsql.EnableRetryOnFailure(3)));
```

### Entity, DbContext, Repository

```csharp
// Data/YourDomainEntity.cs
public sealed class YourDomainEntity
{
    public required string Id { get; set; }
    public required string Reference { get; set; }
    public required string Status { get; set; }
    public required DateTimeOffset CreatedAt { get; set; }
    public required DateTimeOffset UpdatedAt { get; set; }
}

// Data/YourDomainDbContext.cs
public sealed class YourDomainDbContext : DbContext
{
    public YourDomainDbContext(DbContextOptions<YourDomainDbContext> options) : base(options) { }

    public DbSet<YourDomainEntity> Records => Set<YourDomainEntity>();

    protected override void OnModelCreating(ModelBuilder modelBuilder)
    {
        modelBuilder.Entity<YourDomainEntity>(entity =>
        {
            entity.HasKey(e => e.Id);
            entity.Property(e => e.Reference).HasMaxLength(100).IsRequired();
            entity.HasIndex(e => e.Reference).IsUnique();
        });
    }
}

// Data/IYourDomainRepository.cs
public interface IYourDomainRepository
{
    Task<YourDomainEntity?> GetByIdAsync(string id, CancellationToken ct = default);
    Task<YourDomainEntity> CreateAsync(YourDomainEntity entity, CancellationToken ct = default);
    Task<YourDomainEntity> UpdateAsync(YourDomainEntity entity, CancellationToken ct = default);
    Task DeleteAsync(string id, CancellationToken ct = default);
    Task<IReadOnlyList<YourDomainEntity>> ListAsync(int page, int pageSize, CancellationToken ct = default);
}
```

### Explicit mapping — no AutoMapper

```csharp
// Data/YourDomainMappings.cs
internal static class YourDomainMappings
{
    internal static {{ model.names.dot_net_class_name }}Response ToResponse(this YourDomainEntity entity) =>
        new()
        {
            Id = entity.Id,
            Reference = entity.Reference,
            Status = entity.Status,
            CreatedAt = entity.CreatedAt,
            UpdatedAt = entity.UpdatedAt
        };
}
```

