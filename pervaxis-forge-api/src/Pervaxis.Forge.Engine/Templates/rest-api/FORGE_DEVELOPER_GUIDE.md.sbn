## 9. Testing

Use `TestBase` for integration tests, xUnit + Moq for unit tests. Target **90% coverage** — the CI pipeline gates on this.

### Unit test — service logic

```csharp
// Tests/Services/{{ model.names.dot_net_class_name }}Tests.cs
public sealed class {{ model.names.dot_net_class_name }}Tests
{
    private readonly Mock<IYourDomainRepository> _repository = new();
    private readonly Mock<ICache> _cache = new();
    private readonly Mock<ILogger<{{ model.names.dot_net_class_name }}>> _logger = new();
    private readonly {{ model.names.dot_net_class_name }} _sut;

    public {{ model.names.dot_net_class_name }}Tests()
    {
        _sut = new {{ model.names.dot_net_class_name }}(_repository.Object, _cache.Object, _logger.Object);
    }

    [Fact]
    public async Task GetAsync_WhenCached_ReturnsCachedResponse()
    {
        var expected = new {{ model.names.dot_net_class_name }}Response { /* ... */ };
        _cache.Setup(c => c.GetAsync<{{ model.names.dot_net_class_name }}Response>(
                It.IsAny<string>(), default))
              .ReturnsAsync(expected);

        var result = await _sut.GetAsync("1");

        result.Should().Be(expected);
        _repository.Verify(r => r.GetByIdAsync(It.IsAny<string>(), It.IsAny<CancellationToken>()), Times.Never);
    }

    [Fact]
    public async Task GetAsync_WhenNotFound_ThrowsNotFoundException()
    {
        _cache.Setup(c => c.GetAsync<{{ model.names.dot_net_class_name }}Response>(It.IsAny<string>(), default))
              .ReturnsAsync(({{ model.names.dot_net_class_name }}Response?)null);
        _repository.Setup(r => r.GetByIdAsync("missing", default))
                   .ReturnsAsync((YourDomainEntity?)null);

        var act = () => _sut.GetAsync("missing");

        await act.Should().ThrowAsync<YourDomainNotFoundException>();
    }
}
```

