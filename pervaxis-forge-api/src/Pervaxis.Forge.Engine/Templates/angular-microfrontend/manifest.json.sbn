{
  "product": "{{ model.manifest.product }}",
  "verticalSlug": "{{ model.manifest.vertical_slug }}",
  "serviceName": "{{ model.manifest.service_name }}",
  "serviceType": "AngularMfe",
  "componentPrefix": "{{ model.manifest.component_prefix }}",
  "canvasModules": [{{ for m in model.selected_canvas_modules }}"{{ m.name }}"{{ if !for.last }}, {{ end }}{{ end }}]
}
